{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "cdd-web-ui": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "allowedCommonJsDependencies": ["ajv", "ajv-formats"],
            "preserveSymlinks": true,
            "browser": "src/main.ts",
            "polyfills": ["zone.js", "@angular/localize/init"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "node_modules/monaco-editor/min/vs",
                "output": "/assets/vs"
              },
              {
                "glob": "**/*",
                "input": "../cdd-docs-ui/dist",
                "output": "/docs-ui"
              }
            ],
            "styles": ["src/styles.scss"]
          },
          "configurations": {
            "c-only": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.c-only.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5MB",
                  "maximumError": "10MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "assets": [
                {
                  "glob": "favicon.svg",
                  "input": "public",
                  "output": ""
                },
                {
                  "glob": "wasm-support.json",
                  "input": "public/assets",
                  "output": "assets"
                },
                {
                  "glob": "c.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "google.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "openapi.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "cdd-c.wasm",
                  "input": "public/assets/wasm",
                  "output": "assets/wasm"
                },
                {
                  "glob": "**/*",
                  "input": "node_modules/monaco-editor/min/vs",
                  "output": "assets/vs"
                },
                {
                  "glob": "**/*",
                  "input": "../cdd-docs-ui/dist",
                  "output": "/docs-ui"
                }
              ]
            },
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5MB",
                  "maximumError": "10MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "assets": [
                { "glob": "**/*", "input": "public" },
                {
                  "glob": "**/*",
                  "input": "node_modules/monaco-editor/min/vs",
                  "output": "assets/vs"
                },
                { "glob": "**/*", "input": "../cdd-docs-ui/dist", "output": "/docs-ui" }
              ]
            },
            "development": {
              "optimization": {
                "scripts": false,
                "styles": {
                  "minify": false,
                  "inlineCritical": false
                },
                "fonts": {
                  "inline": true
                }
              },
              "extractLicenses": false,
              "sourceMap": true
            },
            "c-only-development": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.c-only.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none",
              "assets": [
                {
                  "glob": "favicon.svg",
                  "input": "public",
                  "output": ""
                },
                {
                  "glob": "wasm-support.json",
                  "input": "public/assets",
                  "output": "assets"
                },
                {
                  "glob": "c.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "google.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "openapi.svg",
                  "input": "public/assets/icons",
                  "output": "assets/icons"
                },
                {
                  "glob": "cdd-c.wasm",
                  "input": "public/assets/wasm",
                  "output": "assets/wasm"
                },
                {
                  "glob": "**/*",
                  "input": "node_modules/monaco-editor/min/vs",
                  "output": "assets/vs"
                },
                {
                  "glob": "**/*",
                  "input": "../cdd-docs-ui/dist",
                  "output": "/docs-ui"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "c-only": {
              "buildTarget": "cdd-web-ui:build:c-only-development"
            },
            "production": {
              "buildTarget": "cdd-web-ui:build:production"
            },
            "development": {
              "buildTarget": "cdd-web-ui:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "proxy.conf.json"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "watch": false
          }
        }
      }
    }
  }
}

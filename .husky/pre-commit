MODE=${PRECOMMIT_MODE:-fast}

if [ "$MODE" = "slow" ]; then
  echo "🐌 Running Precommit Hooks in SLOW mode..."
  echo "To run in fast mode, unset PRECOMMIT_MODE or set it to 'fast'."
  echo ""

  echo "Running Formatters..."
  npm run format
  npm run format:check

  echo "Running Linters..."
  npm run lint

  echo "Running Build..."
  npm run build

  echo "Running Tests with Coverage..."
  npm run test:coverage

  echo "Running E2E Tests..."
  npm run e2e

  echo "Updating Coverage Shields..."
  node scripts/update-shields.mjs

  git add README.md
else
  echo "⚡ Running Precommit Hooks in FAST mode..."
  echo "To run full checks, use: PRECOMMIT_MODE=slow git commit ..."
  echo ""

  echo "Running Formatters..."
  npm run format

  echo "Running Linters..."
  npm run lint

  echo "Running Unit Tests..."
  npm run test
fi

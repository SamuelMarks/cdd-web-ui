{
  "name": "cdd-web-ui",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "prestart": "npm run build:wasm",
    "start": "ng serve",
    "prebuild": "npm run build:wasm",
    "build": "ng build",
    "prebuild:prod": "npm run build:wasm",
    "build:prod": "ng build --configuration production",
    "prebuild:dev": "npm run build:wasm",
    "build:dev": "ng build --configuration development",
    "prebuild:c-only": "npm run build:wasm:local",
    "build:c-only": "ng build --configuration c-only",
    "serve:c-only": "ng serve --configuration c-only",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "e2e": "playwright test",
    "preinstall": "bash scripts/setup-deps.sh",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || echo 'To fix precommit hooks after git clean -fdx, run: npx husky && npm i'",
    "doc": "compodoc -p tsconfig.json",
    "doc:coverage": "compodoc -p tsconfig.json --coverageTest 100",
    "test:coverage": "vitest run --coverage",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:wasm:local": "node scripts/build-wasm.mjs --local",
    "deploy:gh": "npx angular-cli-ghpages --dir=dist/cdd-web-ui/browser"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/localize": "^21.2.11",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@sentry/angular": "^10.45.0",
    "@sentry/tracing": "^7.120.4",
    "@types/d3": "^7.4.3",
    "cdd-ctl-wasm-sdk": "file:../cdd-browser-sdk",
    "cdd-docs-ui": "file:../cdd-docs-ui",
    "d3": "^7.9.0",
    "js-yaml": "^4.1.1",
    "monaco-editor": "^0.55.1",
    "ngx-monaco-editor-v2": "^21.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@angular/platform-browser-dynamic": "^21.2.11",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-cli-ghpages": "^3.0.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.8",
    "zone.js": "^0.16.1"
  }
}
